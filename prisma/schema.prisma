generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum SalaryType {
  HOURLY
  WEEKLY
  MONTHLY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserType {
  SUPER_ADMIN_STAFF
  BRANCH_EMPLOYEE
}

// ─── role ─────────────────────────────────────────────────────────────────────

model role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  superAdminStaff super_admin_staff[]
  branchEmployees branch_employee[]
  rolePermissions rolepermission[]
}

// ─── user ─────────────────────────────────────────────────────────────────────

model user {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String
  userType     UserType
  status       UserStatus @default(ACTIVE)
  lastLogin    DateTime?
  createdAt    DateTime   @default(now())

  // OTP for forgot password
  resetOtp        String?   @db.VarChar(6)
  resetOtpExpiry  DateTime?

  superAdminStaff super_admin_staff?
  branchEmployee  branch_employee?
  auditLogs       auditlog[]
  stockItemsCreated    stock_items[]
  dispatchesSent       stock_dispatches[] @relation("DispatchedBy")
  dispatchesReceived   stock_dispatches[] @relation("ReceivedBy")
  discrepanciesResolved dispatch_discrepancy[]
}

// ─── super_admin_staff ────────────────────────────────────────────────────────

model super_admin_staff {
  id              Int            @id @default(autoincrement())
  staffCode       String         @unique
  firstName       String
  lastName        String
  phone           String?
  gender          String?
  dateOfBirth     DateTime?
  designation     String?
  department      String?
  hireDate        DateTime
  employmentType  EmploymentType
  experienceYears Float?
  status          Boolean        @default(true)
  createdAt       DateTime       @default(now())

  roleId          Int
  role            role           @relation(fields: [roleId], references: [id])

  userId          Int            @unique
  user            user           @relation(fields: [userId], references: [id])

  branchAccess    staff_branch_access[]
}

// ─── staff_branch_access ──────────────────────────────────────────────────────

model staff_branch_access {
  id                Int               @id @default(autoincrement())
  superAdminStaffId Int
  branchId          Int
  staff             super_admin_staff @relation(fields: [superAdminStaffId], references: [id])
  branch            branch            @relation(fields: [branchId], references: [id])
  grantedAt         DateTime          @default(now())

  @@unique([superAdminStaffId, branchId])
}

// ─── branch ───────────────────────────────────────────────────────────────────

model branch {
  id               Int      @id @default(autoincrement())
  branchName       String
  branchCode       String   @unique
  phone            String?
  email            String?
  addressLine1     String?
  city             String?
  state            String?
  country          String?
  postalCode       String?
  latitude         Float?
  longitude        Float?
  openingTime      String?
  closingTime      String?
  deliveryRadiusKm Int?
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())

  employees   branch_employee[]
  staffAccess staff_branch_access[]
  settings    branch_settings?
  dispatchesTo   stock_dispatches[] @relation("DispatchTo")
  inventory      branch_inventory[]
  products       product[]
  orders         order[]
  carts          cart[]
}

// ─── branch_employee ──────────────────────────────────────────────────────────

model branch_employee {
  id              Int            @id @default(autoincrement())
  employeeCode    String         @unique
  firstName       String
  lastName        String
  email           String?
  phone           String?
  gender          String?
  dateOfBirth     DateTime?
  designation     String?
  department      String?
  hireDate        DateTime
  employmentType  EmploymentType
  experienceYears Float?
  status          Boolean        @default(true)
  createdAt       DateTime       @default(now())

  branchId        Int
  branch          branch         @relation(fields: [branchId], references: [id])

  roleId          Int
  role            role           @relation(fields: [roleId], references: [id])

  userId          Int            @unique
  user            user           @relation(fields: [userId], references: [id])

  salary          branch_employee_salary?
}

// ─── branch_employee_salary ───────────────────────────────────────────────────

model branch_employee_salary {
  id            Int             @id @default(autoincrement())
  employeeId    Int             @unique
  employee      branch_employee @relation(fields: [employeeId], references: [id])
  salaryType    SalaryType
  baseSalary    Float
  currency      String          @default("USD")
  payFrequency  String?
  overtimeRate  Float?
  bonus         Float?
  effectiveFrom DateTime
  createdAt     DateTime        @default(now())
}

// ─── permission ───────────────────────────────────────────────────────────────

model permission {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  module          String?
  rolePermissions rolepermission[]
}

// ─── rolepermission ───────────────────────────────────────────────────────────

model rolepermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         role       @relation(fields: [roleId], references: [id])
  permission   permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

// ─── auditlog ─────────────────────────────────────────────────────────────────

model auditlog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        user     @relation(fields: [userId], references: [id])
  performedBy String   // username of who did the action
  action      String
  module      String
  referenceId String?
  details     String?  // extra context e.g. "Created branch: NYC001"
  createdAt   DateTime @default(now())
}

// ─── branch_settings ─────────────────────────────────────────────────────────

model branch_settings {
  id               Int      @id @default(autoincrement())
  branchId         Int      @unique
  branch           branch   @relation(fields: [branchId], references: [id])
  currency         String   @default("INR")
  taxPercentage    Decimal  @db.Decimal(5, 2)
  serviceCharge    Decimal? @db.Decimal(5, 2)
  minOrderAmount   Decimal? @db.Decimal(10, 2)
  deliveryEnabled  Boolean  @default(false)
  dineInEnabled    Boolean  @default(true)
  takeawayEnabled  Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

// ─── warehouse ───────────────────────────────────────────────────────────────

model warehouse {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(150)
  code        String   @unique @db.VarChar(20)
  addressLine1 String? @db.VarChar(255)
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  dispatches         stock_dispatches[]
  warehouseInventory warehouse_inventory[]
}

// ─── stock_categories ────────────────────────────────────────────────────────

model stock_categories {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  stockItems  stock_items[]
}

// ─── stock_items ─────────────────────────────────────────────────────────────

model stock_items {
  id           Int              @id @default(autoincrement())
  uuid         String           @unique @default(uuid()) @db.VarChar(36)
  categoryId   Int
  category     stock_categories @relation(fields: [categoryId], references: [id])
  name         String           @db.VarChar(150)
  sku          String           @unique @db.VarChar(50)
  unit         StockUnit
  reorderLevel Decimal          @db.Decimal(10, 3)
  unitCost     Decimal          @db.Decimal(10, 2)
  description  String?          @db.Text
  isActive     Boolean          @default(true)
  createdBy    Int
  createdByUser user            @relation(fields: [createdBy], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  dispatchItems       stock_dispatch_items[]
  warehouseInventory  warehouse_inventory[]
  branchInventory     branch_inventory[]
  recipes             product_recipe[]
  discrepancies       dispatch_discrepancy[]
}

// ─── stock_dispatches ────────────────────────────────────────────────────────

model stock_dispatches {
  id             Int              @id @default(autoincrement())
  dispatchNumber String           @unique @db.VarChar(30)
  warehouseId    Int
  warehouse      warehouse        @relation(fields: [warehouseId], references: [id])
  toBranchId     Int
  toBranch       branch           @relation("DispatchTo", fields: [toBranchId], references: [id])
  status         DispatchStatus   @default(pending)
  dispatchDate   DateTime         @db.Date
  receivedDate   DateTime?        @db.Date
  notes          String?          @db.Text
  dispatchedBy   Int
  dispatchedByUser user           @relation("DispatchedBy", fields: [dispatchedBy], references: [id])
  receivedBy     Int?
  receivedByUser user?            @relation("ReceivedBy", fields: [receivedBy], references: [id])
  createdAt      DateTime         @default(now())

  items          stock_dispatch_items[]
  discrepancies  dispatch_discrepancy[]
}

// ─── stock_dispatch_items ────────────────────────────────────────────────────

model stock_dispatch_items {
  id               Int              @id @default(autoincrement())
  dispatchId       Int
  dispatch         stock_dispatches @relation(fields: [dispatchId], references: [id])
  stockItemId      Int
  stockItem        stock_items      @relation(fields: [stockItemId], references: [id])
  quantitySent     Decimal          @db.Decimal(10, 3)
  quantityReceived Decimal?         @db.Decimal(10, 3)
  unitCost         Decimal          @db.Decimal(10, 2)
  discrepancyNote  String?          @db.VarChar(255)  // reason if quantity differs
}

// ─── dispatch_discrepancy ────────────────────────────────────────────────────
// Auto-created when received quantity < sent quantity

model dispatch_discrepancy {
  id               Int              @id @default(autoincrement())
  dispatchId       Int
  dispatch         stock_dispatches @relation(fields: [dispatchId], references: [id])
  stockItemId      Int
  stockItem        stock_items      @relation(fields: [stockItemId], references: [id])
  quantitySent     Decimal          @db.Decimal(10, 3)
  quantityReceived Decimal          @db.Decimal(10, 3)
  shortageQty      Decimal          @db.Decimal(10, 3)  // sent - received
  reason           String?          @db.VarChar(255)
  resolvedAt       DateTime?
  resolvedBy       Int?
  resolvedByUser   user?            @relation(fields: [resolvedBy], references: [id])
  createdAt        DateTime         @default(now())
}

// ─── Enums for stock ─────────────────────────────────────────────────────────

enum StockUnit {
  kg
  g
  litre
  ml
  piece
  pack
}

enum DispatchStatus {
  pending
  dispatched
  partially_received
  received
  rejected
}

// ─── warehouse_inventory ─────────────────────────────────────────────────────

model warehouse_inventory {
  id          Int       @id @default(autoincrement())
  warehouseId Int
  stockItemId Int
  quantity    Decimal   @db.Decimal(10, 3)
  warehouse   warehouse @relation(fields: [warehouseId], references: [id])
  stockItem   stock_items @relation(fields: [stockItemId], references: [id])
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, stockItemId])
}

// ─── branch_inventory ────────────────────────────────────────────────────────

model branch_inventory {
  id          Int     @id @default(autoincrement())
  branchId    Int
  stockItemId Int
  quantity    Decimal @db.Decimal(10, 3)
  branch      branch  @relation(fields: [branchId], references: [id])
  stockItem   stock_items @relation(fields: [stockItemId], references: [id])
  updatedAt   DateTime @updatedAt

  @@unique([branchId, stockItemId])
}

// ─── product ─────────────────────────────────────────────────────────────────

model product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  description String?  @db.Text
  branchId    Int
  branch      branch   @relation(fields: [branchId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  variants    product_variant[]
  recipes     product_recipe[]
  orderItems  order_item[]
  cartItems   cart_item[]
}

// ─── product_variant ─────────────────────────────────────────────────────────

model product_variant {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String  @db.VarChar(100)
  price     Decimal @db.Decimal(10, 2)
  isActive  Boolean @default(true)
  product   product @relation(fields: [productId], references: [id])
}

// ─── product_recipe ──────────────────────────────────────────────────────────

model product_recipe {
  id           Int         @id @default(autoincrement())
  productId    Int
  stockItemId  Int
  quantityUsed Decimal     @db.Decimal(10, 3)
  product      product     @relation(fields: [productId], references: [id])
  stockItem    stock_items @relation(fields: [stockItemId], references: [id])

  @@unique([productId, stockItemId])
}

// ─── order ───────────────────────────────────────────────────────────────────

model order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique @db.VarChar(30)
  branchId        Int
  branch          branch        @relation(fields: [branchId], references: [id])
  customerId      Int?
  customer        customer?     @relation(fields: [customerId], references: [id])
  guestToken      String?       @db.VarChar(100)
  customerName    String?       @db.VarChar(100)
  customerPhone   String?       @db.VarChar(20)
  orderType       OrderType
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  couponDiscount  Decimal       @default(0) @db.Decimal(10, 2)
  loyaltyDiscount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  couponId        Int?
  coupon          coupon?       @relation(fields: [couponId], references: [id])
  loyaltyPointsUsed Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           order_item[]
  payment         payment?
  delivery        delivery?
  statusHistory   order_status_history[]
  loyaltyTxns     loyalty_transaction[]
  couponUsage     coupon_usage?
}

// ─── order_item ──────────────────────────────────────────────────────────────

model order_item {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  variantId Int?
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     order   @relation(fields: [orderId], references: [id])
  product   product @relation(fields: [productId], references: [id])
}

// ─── payment ─────────────────────────────────────────────────────────────────

model payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        String        @db.VarChar(50)
  status        PaymentStatus @default(PENDING)
  transactionId String?       @db.VarChar(100)
  paidAt        DateTime?
  order         order         @relation(fields: [orderId], references: [id])
  createdAt     DateTime      @default(now())
}

// ─── coupon ──────────────────────────────────────────────────────────────────

model coupon {
  id            Int          @id @default(autoincrement())
  code          String       @unique @db.VarChar(50)
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  orders        order[]
  usages        coupon_usage[]
}

// ─── loyalty_wallet ──────────────────────────────────────────────────────────

model loyalty_wallet {
  id         Int      @id @default(autoincrement())
  customerId String   @unique @db.VarChar(100)
  points     Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt  DateTime @updatedAt
}

// ─── vip_plan ────────────────────────────────────────────────────────────────

model vip_plan {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  price       Decimal  @db.Decimal(10, 2)
  durationDays Int
  benefits    String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── delivery ────────────────────────────────────────────────────────────────

model delivery {
  id              Int      @id @default(autoincrement())
  orderId         Int      @unique
  order           order    @relation(fields: [orderId], references: [id])
  deliveryAddress String   @db.Text
  status          String   @default("pending") @db.VarChar(30)
  assignedTo      Int?
  estimatedTime   DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
}

// ─── notification ────────────────────────────────────────────────────────────

model notification {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(150)
  message   String   @db.Text
  type      String   @db.VarChar(50)
  branchId  Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── New enums ────────────────────────────────────────────────────────────────

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum CartStatus {
  ACTIVE
  ORDERED
  ABANDONED
}

// ─── customer ─────────────────────────────────────────────────────────────────

model customer {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  phone         String   @unique @db.VarChar(20)
  email         String?  @unique @db.VarChar(100)
  passwordHash  String?
  loyaltyPoints Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  // OTP for forgot password
  resetOtp        String?   @db.VarChar(6)
  resetOtpExpiry  DateTime?

  addresses     customer_address[]
  orders        order[]
  carts         cart[]
  loyaltyTxns   loyalty_transaction[]
  couponUsages  coupon_usage[]
}

// ─── customer_address ────────────────────────────────────────────────────────

model customer_address {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   customer @relation(fields: [customerId], references: [id])
  address    String   @db.VarChar(255)
  city       String   @db.VarChar(100)
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── cart ─────────────────────────────────────────────────────────────────────

model cart {
  id         Int        @id @default(autoincrement())
  customerId Int?
  customer   customer?  @relation(fields: [customerId], references: [id])
  guestToken String?    @db.VarChar(100)  // for guest users
  branchId   Int
  branch     branch     @relation(fields: [branchId], references: [id])
  status     CartStatus @default(ACTIVE)
  couponCode String?    @db.VarChar(50)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  items      cart_item[]
}

// ─── cart_item ────────────────────────────────────────────────────────────────

model cart_item {
  id        Int     @id @default(autoincrement())
  cartId    Int
  cart      cart    @relation(fields: [cartId], references: [id])
  productId Int
  product   product @relation(fields: [productId], references: [id])
  variantId Int?
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
}

// ─── coupon_usage ─────────────────────────────────────────────────────────────

model coupon_usage {
  id         Int      @id @default(autoincrement())
  couponId   Int
  coupon     coupon   @relation(fields: [couponId], references: [id])
  customerId Int?
  customer   customer? @relation(fields: [customerId], references: [id])
  guestToken String?  @db.VarChar(100)
  orderId    Int      @unique
  order      order    @relation(fields: [orderId], references: [id])
  createdAt  DateTime @default(now())
}

// ─── loyalty_transaction ─────────────────────────────────────────────────────

model loyalty_transaction {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   customer @relation(fields: [customerId], references: [id])
  points     Decimal  @db.Decimal(10, 2)
  type       String   @db.VarChar(10)  // EARN or REDEEM
  orderId    Int?
  order      order?   @relation(fields: [orderId], references: [id])
  createdAt  DateTime @default(now())
}

// ─── order_status_history ────────────────────────────────────────────────────

model order_status_history {
  id        Int         @id @default(autoincrement())
  orderId   Int
  order     order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  changedAt DateTime    @default(now())
  changedBy Int?
}
